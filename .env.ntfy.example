NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=replace-with-your-unique-topic
NTFY_TITLE="NQ Trade Alert"
NTFY_PRIORITY=4
NTFY_TAGS=chart_with_upwards_trend,rotating_light

# Optional token for protected/self-hosted topics
# NTFY_TOKEN=

# Local API default (change if you use Render backend)
NQ_DASHBOARD_API_URL=http://localhost:8080/api/dashboard

# Alert behavior
NQ_ALERT_POLL_SEC=5
NQ_REQUIRE_ELIGIBLE=true
NQ_SEND_EVERY_DIRECTIONAL=false
